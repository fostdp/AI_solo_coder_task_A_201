# ============================================
# 数据库配置
# ============================================
MONGODB_URL=mongodb://mongodb:27017/?replicaSet=rs0
DATABASE_NAME=lost_wax_casting

# ============================================
# Redis配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# MQTT配置
# ============================================
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC=lwc/sensor/data/#
MQTT_CLIENT_ID=dtu-receiver

# ============================================
# 后端服务配置
# ============================================
GUNICORN_WORKERS=4
LOG_LEVEL=info

# ============================================
# API配置（模拟器用）
# ============================================
API_BASE_URL=http://backend:8000

# ============================================
# 模拟器配置
# ============================================
SIMULATOR_INTERVAL=3
SIMULATOR_STEPS=60
SIMULATOR_ALLOY=bronze_cu_sn
SIMULATOR_SHELL=silica_sol
SIMULATOR_DEFECT_INTENSITY=1.0
